{
  "name": "tydei-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true bun run build",
    "start": "next start",
    "lint": "oxlint .",
    "db:push": "prisma db push --config prisma/prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "db:seed": "bun run prisma/seed.ts && bun run scripts/qa-sanity.ts",
    "db:studio": "prisma studio --config prisma/prisma.config.ts",
    "qa:sanity": "bun run scripts/qa-sanity.ts",
    "qa:seed": "bun run scripts/qa-sanity.ts",
    "qa:dom-diff": "bun run scripts/dual-app-dom-diff.ts",
    "qa:workflows": "bun run tests/workflows/run-all.ts",
    "qa:v0-ledger": "bun run scripts/build-v0-feature-ledger.ts",
    "qa:v0-ledger-check": "bun run scripts/build-v0-feature-ledger.ts --check",
    "smoke": "bun run scripts/pre-ship-smoke.ts",
    "lint:ai": "bun run scripts/lint-ai-action-error-paths.ts",
    "oracles": "bun scripts/oracles/index.ts",
    "lint:ai-schema": "bun run scripts/lint-ai-schema-describe.ts",
    "test:unit": "bunx vitest run --exclude '**/.claude/**' --exclude '**/.worktrees/**' --exclude '**/*.integration.test.ts'",
    "test:integration": "RUN_INTEGRATION=1 bunx vitest run '**/*.integration.test.ts'",
    "test:e2e": "bunx playwright test --project=e2e-setup --project=e2e",
    "test:visual": "bunx playwright test --project=visual-setup --project=visual",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/react": "^3.0.170",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@better-auth/stripe": "^1.6.9",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.168",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.12.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.11",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod-prisma-types": "^3.3.11"
  }
}
