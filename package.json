{
  "name": "tydei-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true bun run build",
    "start": "next start",
    "lint": "oxlint .",
    "db:push": "prisma db push --config prisma/prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "db:seed": "bun run prisma/seed.ts && bun run scripts/qa-sanity.ts",
    "db:studio": "prisma studio --config prisma/prisma.config.ts",
    "qa:sanity": "bun run scripts/qa-sanity.ts",
    "qa:seed": "bun run scripts/qa-sanity.ts",
    "qa:dom-diff": "bun run scripts/dual-app-dom-diff.ts",
    "qa:workflows": "bun run tests/workflows/run-all.ts",
    "qa:v0-ledger": "bun run scripts/build-v0-feature-ledger.ts",
    "qa:v0-ledger-check": "bun run scripts/build-v0-feature-ledger.ts --check",
    "smoke": "bun run scripts/pre-ship-smoke.ts",
    "lint:ai": "bun run scripts/lint-ai-action-error-paths.ts",
    "oracles": "bun scripts/oracles/index.ts",
    "lint:ai-schema": "bun run scripts/lint-ai-schema-describe.ts",
    "test:unit": "bunx vitest run --exclude '**/.claude/**' --exclude '**/.worktrees/**' --exclude '**/*.integration.test.ts'",
    "test:integration": "RUN_INTEGRATION=1 bunx vitest run '**/*.integration.test.ts'",
    "test:e2e": "bunx playwright test --project=e2e-setup --project=e2e",
    "test:visual": "bunx playwright test --project=visual-setup --project=visual",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/react": "^3.0.186",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@better-auth/stripe": "^1.6.11",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.184",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-resizable-panels": "^4.11.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.65.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "zod-prisma-types": "^3.3.11"
  }
}
