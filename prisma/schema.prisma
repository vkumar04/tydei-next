// ─── Tie-In Bundles ───────────────────────────────────────────────

model TieInBundle {
  id                String    @id @default(cuid())
  primaryContractId String    @unique
  complianceMode   TieInMode @default(all_or_nothing)
  // Charles 2026-04-23 — v0 spec bundle rebate structure.
  //   baseRate: integer percent applied when all members are compliant.
  //   bonusRate: added when every member is ≥120% of its minimum.
  //   acceleratorMultiplier: multiplies (base+bonus) when every member
  //     is ≥150%. Existing `bonusMultiplier` column is retained for
  //     back-compat with pre-spec bundles and maps to acceleratorMultiplier
  //     if non-null and acceleratorMultiplier is null.
  baseRate              Decimal? @db.Decimal(5, 2)
  bonusRate             Decimal? @db.Decimal(5, 2)
  acceleratorMultiplier Decimal? @db.Decimal(4, 2)
  bonusMultiplier       Decimal? @db.Decimal(5, 4)
  // Bundle active window. Nullable so migrations don't require a
  // default; server compute falls back to min/max of member contracts.
  effectiveStart        DateTime?
  effectiveEnd          DateTime?
  // Cross-vendor bundle's facility-level bonus (e.g. from GPO). Applies
  // the rate to total spend when every member is compliant. complianceMode
  // = cross_vendor is the only mode that reads this pair.
  facilityBonusRate     Decimal? @db.Decimal(5, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  primaryContract Contract            @relation("PrimaryContract", fields: [primaryContractId], references: [id], onDelete: Cascade)
  members         TieInBundleMember[]

  @@map("tie_in_bundle")
}

model TieInBundleMember {
  id            String   @id @default(cuid())
  bundleId      String
  // Charles 2026-04-23 — contractId now nullable. Cross-vendor members
  // may reference a vendor directly without a full contract row. For
  // all-or-nothing / proportional bundles contractId must be set.
  contractId    String?
  vendorId      String?
  weightPercent Decimal  @db.Decimal(5, 2)
  minimumSpend  Decimal? @db.Decimal(14, 2)
  // Integer percent applied to this member's spend on cross_vendor
  // bundles (e.g. Suture Co contributes 2% on its own spend).
  rebateContribution Decimal? @db.Decimal(5, 2)
  createdAt     DateTime @default(now())

  bundle   TieInBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  contract Contract?   @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // `@@unique([bundleId, contractId])` was dropped to allow null
  // contractId on cross-vendor members. Uniqueness is now enforced in
  // the server action that writes the member.
  @@index([bundleId])
  @@map("tie_in_bundle_member")
}

// ─── Pending Contracts (Vendor Submissions) ───────────────────────

/**
 * Charles 2026-04-25 (audit follow-up): in-app notifications
 * complement the email path in `lib/actions/notifications.ts`.
 * Today the system fires emails on pending-contract submit /
 * approve / reject / revision-request — but if the recipient
 * doesn't check email, they miss it. A notification record + a
 * top-bar bell gives the user a persistent, in-app surface.
 *
 * Read state is tracked via `readAt` (null = unread). Polymorphic
 * `payload` Json carries type-specific metadata (e.g. pendingId,
 * contractId, decision) so the UI can deep-link without a separate
 * column per type.
 */
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  /** Type-specific metadata, e.g. { pendingId, contractId, decision }. */
  payload   Json?
  /** Where to deep-link when the user clicks the notification. */
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notification")
}

model PendingContract {
  id             String                @id @default(cuid())
  vendorId       String
  vendorName     String
  facilityId     String?
  facilityName   String?
  contractName   String
  contractType   ContractType          @default(usage)
  status         PendingContractStatus @default(submitted)
  effectiveDate  DateTime?             @db.Date
  expirationDate DateTime?             @db.Date
  totalValue     Decimal?              @db.Decimal(14, 2)
  // Charles 2026-04-25 (vendor-mirror Phase 2): field-parity columns
  // so vendor submissions don't drop data on the floor. The vendor
  // submission UI already collected most of these in local state;
  // they were silently dropped at the server boundary because no
  // column existed. All optional/nullable so existing rows in older
  // databases stay valid.
  contractNumber        String?
  annualValue           Decimal?              @db.Decimal(14, 2)
  gpoAffiliation        String?
  performancePeriod     String?
  rebatePayPeriod       String?
  autoRenewal           Boolean               @default(false)
  terminationNoticeDays Int?
  // Charles 2026-04-25 (vendor-mirror Phase 2 cont.): capital tie-in
  // fields so vendors can submit capital + tie-in contracts without
  // the financial structure dropping at approval. Mirror the names
  // on the real Contract model so approve can copy through cleanly.
  capitalCost       Decimal? @db.Decimal(14, 2)
  interestRate      Decimal? @db.Decimal(6, 4)
  termMonths        Int?
  downPayment       Decimal? @db.Decimal(14, 2)
  paymentCadence    String?
  amortizationShape String?
  // Charles audit suggestion #4 (v0-port): multi-item capital on
  // vendor submission. JSON blob of CapitalLineItemDraft[]. Approve
  // path drains this into ContractCapitalLineItem rows on the
  // approved Contract. The single-block capital fields above stay
  // for backward compat with older clients.
  capitalLineItems  Json?
  // Charles 2026-04-25 audit pass-3 C1: vendor selects a parent
  // contract for tie-in submissions; the validator already accepts
  // the field but it was being silently dropped because no column
  // existed. Approve copies it onto Contract.tieInContractId so the
  // capital amortization tie-in math is wired post-approve.
  tieInContractId   String?
  // Vendor's organizational division (e.g. "Surgical", "Cardiology").
  division          String?
  terms          Json                  @default("[]")
  documents      Json                  @default("[]")
  pricingData    Json?
  notes          String?
  submittedAt    DateTime              @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?
  reviewNotes    String?

  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([vendorId])
  @@index([facilityId])
  @@index([status])
  @@map("pending_contract")
}

