model Rebate {
  id              String    @id @default(cuid())
  contractId      String
  facilityId      String
  periodId        String?
  rebateEarned    Decimal   @db.Decimal(14, 2)
  rebateCollected Decimal   @default(0) @db.Decimal(14, 2)
  rebateUnearned  Decimal   @default(0) @db.Decimal(14, 2)
  payPeriodStart  DateTime  @db.Date
  payPeriodEnd    DateTime  @db.Date
  collectionDate  DateTime? @db.Date
  notes           String?
  // Roadmap track 2: engine version stamping. Rebate rows written by
  // the accrual engine carry the engine version that computed them —
  // when the engine's math changes (e.g. 2026-04-20's below-baseline
  // fix), old rows stay stamped with the old version so a targeted
  // recompute can upgrade them deterministically. Null = manual-entry
  // row or pre-2026-04-20 row that predates version tracking.
  engineVersion   String?
  // Roadmap track 2: warnings channel. When the canonical engine
  // returns `warnings[]` on a RebateResult (e.g. "PRIOR_YEAR_ACTUAL
  // baseline missing, defaulted to 0"), the recompute pipeline
  // serializes them into this column as a newline-joined string.
  // Surfaced on the ledger UI as a yellow banner.
  engineWarnings  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contract Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  facility Facility        @relation(fields: [facilityId], references: [id])
  period   ContractPeriod? @relation(fields: [periodId], references: [id])

  @@index([contractId])
  @@map("rebate")
}

